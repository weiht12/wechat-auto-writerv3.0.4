<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>公众号写作助手 v3.0</title>
  <link rel="stylesheet" href="style.css?v=20260324i" />

  <!-- marked.js for markdown rendering -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>
  <!-- ── 侧边导航 ───────────────────────────────────────────── -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
      </div>
      <div class="logo-text">
        <span class="logo-title">公众号写作助手</span>
        <span class="logo-sub">v3.0 智能内容中枢</span>
      </div>
    </div>

    <nav class="sidebar-nav">
      <a class="nav-item active" data-page="dashboard">
        <svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
        <span>仪表盘</span>
      </a>
      <a class="nav-item" data-page="hot">
        <svg viewBox="0 0 24 24"><path d="M13.5 0.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5 0.67zM11.71 19c-1.78 0-3.22-1.4-3.22-3.14 0-1.62 1.05-2.76 2.81-3.12 1.77-.36 3.6-1.21 4.62-2.58.39 1.29.59 2.65.59 4.04 0 2.65-2.15 4.8-4.8 4.8z"/></svg>
        <span>每日热点</span>
        <span class="badge" id="badge-hot"></span>
      </a>
      <a class="nav-item" data-page="write">
        <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
        <span>生成文章</span>
      </a>
      <a class="nav-item" data-page="profile">
        <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
        <span>风格档案</span>
      </a>
      <a class="nav-item" data-page="history">
        <svg viewBox="0 0 24 24"><path d="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C8.27 19.99 10.51 21 13 21c4.97 0 9-4.03 9-9s-4.03-9-9-9zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/></svg>
        <span>历史文章</span>
      </a>
      <a class="nav-item" data-page="imitate">
        <svg viewBox="0 0 24 24"><path d="M9 11.75A1.25 1.25 0 1 0 9 14.25 1.25 1.25 0 0 0 9 11.75zm6 0a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8 0-.29.02-.58.05-.86 2.36-1.05 4.23-2.98 5.21-5.37C11.07 8.33 14.05 10 17.42 10c.78 0 1.53-.09 2.25-.26.21.71.33 1.47.33 2.26 0 4.41-3.59 8-8 8z"/></svg>
        <span>参考仿写</span>
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="status-dot" id="ai-status-dot"></div>
      <span id="ai-status-text">检测中...</span>
    </div>
  </aside>

  <!-- ── 主内容区 ──────────────────────────────────────────── -->
  <main class="main">

    <!-- ═══════════ 仪表盘 ═══════════ -->
    <section id="page-dashboard" class="page active">
      <div class="page-header">
        <h1 class="page-title">仪表盘</h1>
        <p class="page-desc">欢迎回来，堂主！今天也是为河南发声的一天。</p>
      </div>

      <div class="cards-grid">
        <div class="card card-accent">
          <div class="card-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg></div>
          <div class="card-body">
            <div class="card-label">风格档案</div>
            <div class="card-value" id="stat-profile">加载中...</div>
            <div class="card-meta" id="stat-profile-meta"></div>
          </div>
        </div>
        <div class="card">
          <div class="card-icon card-icon-orange"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l7.59-7.59L21 8l-9 9z"/></svg></div>
          <div class="card-body">
            <div class="card-label">历史文章库</div>
            <div class="card-value" id="stat-articles">加载中...</div>
            <div class="card-meta" id="stat-articles-meta"></div>
          </div>
        </div>
        <div class="card">
          <div class="card-icon card-icon-green"><svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg></div>
          <div class="card-body">
            <div class="card-label">已生成文章</div>
            <div class="card-value" id="stat-output">加载中...</div>
            <div class="card-meta" id="stat-output-meta"></div>
          </div>
        </div>
        <div class="card">
          <div class="card-icon card-icon-red"><svg viewBox="0 0 24 24"><path d="M13.5 0.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5 0.67z"/></svg></div>
          <div class="card-body">
            <div class="card-label">今日热点缓存</div>
            <div class="card-value" id="stat-hot">加载中...</div>
            <div class="card-meta" id="stat-hot-meta"></div>
          </div>
        </div>
      </div>

      <!-- 快捷操作 -->
      <div class="section-title">快捷操作</div>
      <div class="quick-actions">
        <button class="btn btn-primary btn-large" data-page="hot">
          <svg viewBox="0 0 24 24"><path d="M13.5 0.67s.74 2.65.74 4.8c0 2.06-1.35 3.73-3.41 3.73-2.07 0-3.63-1.67-3.63-3.73l.03-.36C5.21 7.51 4 10.62 4 14c0 4.42 3.58 8 8 8s8-3.58 8-8C20 8.61 17.41 3.8 13.5 0.67z"/></svg>
          查看今日热点
        </button>
        <button class="btn btn-secondary btn-large" data-page="write">
          <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
          立即写文章
        </button>
        <button class="btn btn-ghost btn-large" data-page="profile">
          <svg viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
          查看风格档案
        </button>
      </div>

      <!-- 最近文章 -->
      <div class="section-title" style="margin-top:2rem">最近生成的文章</div>
      <div class="article-list" id="recent-articles">
        <div class="loading-state">加载中...</div>
      </div>
    </section>

    <!-- ═══════════ 每日热点 ═══════════ -->
    <section id="page-hot" class="page">
      <div class="page-header">
        <h1 class="page-title">每日热点</h1>
        <p class="page-desc" id="hot-date-desc">正在加载今日河南热点...</p>
      </div>

      <!-- Tab 切换：本地热点 / 全网热点 -->
      <div class="hot-tabs">
        <button class="hot-tab active" id="hot-tab-local" onclick="switchHotTab('local')">
          <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          本地热点
        </button>
        <button class="hot-tab" id="hot-tab-global" onclick="switchHotTab('global')">
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
          全网热点
        </button>
      </div>

      <!-- ─── 本地热点内容 ─── -->
      <div id="hot-content-local">
        <!-- 消息源管理栏 -->
        <div class="source-chips-row" id="source-chips-row">
          <!-- 内置消息源（不可删除） -->
          <div class="source-chip builtin" id="src-chip-dahecube">
            <span class="source-chip-dot" id="src-dot-dahecube"></span>
            <span class="source-chip-name">大河财立方</span>
            <span style="color:var(--text-muted);font-size:11px" id="src-count-dahecube"></span>
          </div>
          <div class="source-chip builtin" id="src-chip-gov">
            <span class="source-chip-dot" id="src-dot-gov"></span>
            <span class="source-chip-name">河南省政府</span>
            <span style="color:var(--text-muted);font-size:11px" id="src-count-gov"></span>
          </div>
          <div class="source-chip builtin" id="src-chip-baidu">
            <span class="source-chip-dot" id="src-dot-baidu"></span>
            <span class="source-chip-name">百度新闻</span>
            <span style="color:var(--text-muted);font-size:11px" id="src-count-baidu"></span>
          </div>
          <!-- 自定义消息源动态插入 -->
          <div id="custom-source-chips"></div>
          <!-- 添加按钮 -->
          <button class="btn-add-source" onclick="showAddSourceModal()">
            <svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
            添加消息源
          </button>
          <!-- 刷新按钮 -->
          <button class="btn btn-ghost btn-sm" onclick="loadHotTopics(true)" id="btn-refresh" style="margin-left:auto">
            <svg viewBox="0 0 24 24"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
            刷新热点
          </button>
        </div>

        <!-- 进度条 -->
        <div class="progress-bar" id="hot-progress" style="display:none">
          <div class="progress-fill"></div>
        </div>
        <div class="progress-msg" id="hot-progress-msg"></div>

        <!-- 热点列表 -->
        <div id="hot-topics-list" class="topics-list"></div>
      </div>

      <!-- ─── 全网热点内容 ─── -->
      <div id="hot-content-global" style="display:none">
        <!-- 时间范围选项 -->
        <div class="time-range-tabs">
          <button class="time-range-tab active" id="trt-realtime" onclick="switchTimeRange('realtime')">实时</button>
          <button class="time-range-tab" id="trt-24h" onclick="switchTimeRange('24h')">24小时</button>
          <button class="time-range-tab" id="trt-7d" onclick="switchTimeRange('7d')">7天</button>
        </div>

        <!-- 搜索栏 -->
        <div class="global-hot-controls">
          <div class="form-group flex-1">
            <input type="text" class="form-input" id="global-hot-query" placeholder="输入关键词搜索全网热点（留空搜索今日河南热点）" />
          </div>
          <button class="btn btn-primary" id="btn-global-search" onclick="loadGlobalHot()">
            <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
            搜索全网
          </button>
        </div>

        <!-- 全网热点进度 -->
        <div class="progress-bar" id="global-hot-progress" style="display:none">
          <div class="progress-fill"></div>
        </div>
        <div class="progress-msg" id="global-hot-msg"></div>

        <!-- 来源状态（Tavily） -->
        <div class="source-bar" id="global-source-bar" style="display:none; margin-bottom:12px;">
          <div class="source-item">
            <span class="source-dot" id="global-src-dot"></span>
            <span class="source-label">Tavily</span>
            <span class="source-count" id="global-src-count">-</span>
          </div>
        </div>

        <!-- 全网热点列表 -->
        <div id="global-hot-list" class="topics-list"></div>
      </div>

      <!-- 添加消息源弹窗 -->
      <div class="modal-overlay" id="add-source-modal" onclick="closeAddSourceModal(event)">
        <div class="modal modal-sm">
          <div class="modal-header">
            <h2 class="modal-title">添加自定义消息源</h2>
            <button class="modal-close" onclick="document.getElementById('add-source-modal').classList.remove('open')">✕</button>
          </div>
          <div class="modal-body">
            <div class="form-group" style="margin-bottom:12px">
              <label class="form-label">消息源名称 <span class="required">*</span></label>
              <input type="text" class="form-input" id="new-source-name" placeholder="如：河南日报、大象新闻..." />
            </div>
            <div class="form-group" style="margin-bottom:12px">
              <label class="form-label">网站地址 <span class="required">*</span></label>
              <input type="text" class="form-input" id="new-source-url" placeholder="https://..." />
            </div>
            <div class="form-group" style="margin-bottom:16px">
              <label class="form-label">CSS 选择器（可选）</label>
              <input type="text" class="form-input" id="new-source-selector" placeholder="留空则自动解析，如：.news-list a" />
              <div style="font-size:12px;color:var(--text-muted);margin-top:4px">指定标题链接选择器可提高抓取精度</div>
            </div>
            <div class="btn-row">
              <button class="btn btn-primary" onclick="addCustomSource()">添加</button>
              <button class="btn btn-ghost" onclick="document.getElementById('add-source-modal').classList.remove('open')">取消</button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════ 生成文章 ═══════════ -->
    <section id="page-write" class="page page-write-layout">
      <div class="page-header">
        <h1 class="page-title">生成文章</h1>
        <p class="page-desc">输入关键词，AI 将参考堂主风格进行聚合改写</p>
      </div>

      <!-- 左右双栏主体 -->
      <div class="write-cols">

        <!-- 左侧：操作区 -->
        <div class="write-col-main">

          <!-- Step 1: 关键词 + 文章选择 -->
          <div class="write-panel" id="write-step1">
        <div class="panel-header">
          <span class="step-badge">Step 1</span>
          <span>搜索新闻素材</span>
        </div>
        <div class="panel-body">
          <div class="form-row">
            <div class="form-group flex-1">
              <label class="form-label">搜索关键词</label>
              <input type="text" class="form-input" id="kw-input" placeholder="如：郑州机场、河南高铁、郑州都市圈..." />
            </div>
            <div class="form-group">
              <label class="form-label">抓取数量</label>
              <select class="form-select" id="count-select">
                <option value="3">3篇（快速）</option>
                <option value="5" selected>5篇（推荐）</option>
                <option value="8">8篇（丰富）</option>
              </select>
            </div>
            <div class="form-group form-btn-group">
              <button class="btn btn-primary" id="btn-fetch" onclick="fetchNews()">
                <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                搜索新闻
              </button>
            </div>
          </div>

          <!-- Tavily 全网搜索开关 -->
          <div class="tavily-toggle-row">
            <label class="toggle-switch">
              <input type="checkbox" id="tavily-enabled" />
              <span class="toggle-slider"></span>
              <span class="toggle-label">启用 Tavily 全网搜索</span>
            </label>
            <span class="toggle-desc">搜索结果将包含全网相关新闻，不再局限于固定源</span>
          </div>

          <!-- 新闻列表 -->
          <div id="news-list" class="news-list" style="display:none"></div>
        </div>
      </div>

      <!-- Step 2: 文章生成 -->
      <div class="write-panel" id="write-step2" style="display:none">
        <div class="panel-header">
          <span class="step-badge step-badge-2">Step 2</span>
          <span>AI 聚合改写</span>
          <span class="badge-selected" id="selected-count-badge"></span>
        </div>
        <div class="panel-body">
          <!-- 写作模式选择 -->
          <div class="mode-selector">
            <label class="mode-option mode-option-default active" id="mode-default">
              <input type="radio" name="write-mode" value="default" checked onchange="switchWriteMode('default')" />
              <div class="mode-card">
                <div class="mode-icon">⚡</div>
                <div class="mode-title">直接AI聚合改写</div>
                <div class="mode-desc">AI 自主分析选定文章，融合堂主风格自动生成文章</div>
              </div>
            </label>
            <label class="mode-option" id="mode-custom">
              <input type="radio" name="write-mode" value="custom" onchange="switchWriteMode('custom')" />
              <div class="mode-card">
                <div class="mode-icon">🎯</div>
                <div class="mode-title">自定义写作方向</div>
                <div class="mode-desc">指定文章主题方向或提供大纲，AI 按你的意图创作</div>
              </div>
            </label>
          </div>

          <!-- 自定义方向表单（默认隐藏） -->
          <div class="custom-direction-form" id="custom-direction-form" style="display:none">
            <div class="form-group">
              <label class="form-label">写作方向说明</label>
              <textarea class="form-textarea" id="custom-direction" rows="3"
                placeholder="简要说明你想让文章从哪个角度切入&#10;例如：&#10;• 从读者视角解读政策，重点讲实惠&#10;• 侧重数据对比，用图表形式呈现&#10;• 以讲故事的方式，穿插典型案例"></textarea>
            </div>
            <div class="form-group">
              <label class="form-label">文章大纲（可选）</label>
              <textarea class="form-textarea" id="custom-outline" rows="5"
                placeholder="如果需要，可以提供文章大纲，AI 将严格按大纲展开&#10;例如：&#10;1. 引言：郑州地铁现状与规划背景&#10;2. 主体：三条新线详情（长度、站点、特色）&#10;3. 数据对比：与其他城市地铁发展情况&#10;4. 展望：对市民生活的影响"></textarea>
            </div>

            <!-- 深度研究选项 -->
            <div class="research-toggle-row">
