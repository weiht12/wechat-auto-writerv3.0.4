                  </label>
                </div>
              </div>

              <!-- Tavily 开关 -->
              <div class="feature-toggle-row">
                <div class="feature-toggle-info">
                  <span class="feature-icon">🌐</span>
                  <div>
                    <div class="feature-name">Tavily 补充材料</div>
                    <div class="feature-desc">自动搜索最新资料，丰富文章内容</div>
                  </div>
                </div>
                <label class="toggle-switch">
                  <input type="checkbox" id="imitate-tavily-enabled" />
                  <span class="toggle-slider"></span>
                </label>
              </div>

              <div class="imitate-hint" id="imitate-hint">
                <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                请先在左侧勾选 1~5 篇参考文章，AI 将学习它们的风格进行创作
              </div>

              <!-- 仿写进度 -->
              <div id="imitate-progress-area" style="display:none">
                <div class="write-steps">
                  <div class="write-step" id="istep-1"><span class="wstep-icon">⏳</span><span>读取参考</span></div>
                  <div class="write-step" id="istep-2"><span class="wstep-icon">⏳</span><span>分析风格</span></div>
                  <div class="write-step" id="istep-3"><span class="wstep-icon">⏳</span><span>AI仿写</span></div>
                  <div class="write-step" id="istep-4"><span class="wstep-icon">⏳</span><span>保存</span></div>
                </div>
                <div class="write-progress-msg" id="imitate-progress-msg"></div>
              </div>

              <button class="btn btn-primary btn-large w-full" id="btn-imitate" onclick="startImitate()" style="margin-top:1rem">
                <svg viewBox="0 0 24 24"><path d="M9 11.75A1.25 1.25 0 1 0 9 14.25 1.25 1.25 0 0 0 9 11.75zm6 0a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5zM12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8 0-.29.02-.58.05-.86 2.36-1.05 4.23-2.98 5.21-5.37C11.07 8.33 14.05 10 17.42 10c.78 0 1.53-.09 2.25-.26.21.71.33 1.47.33 2.26 0 4.41-3.59 8-8 8z"/></svg>
                开始仿写
              </button>
            </div>
          </div>

          <!-- 仿写结果 -->
          <div class="write-panel" id="imitate-result" style="display:none">
            <div class="panel-header">
              <span class="step-badge step-badge-3">完成</span>
              <span id="imitate-result-title">仿写结果</span>
              <div class="result-actions">
                <button class="btn btn-ghost btn-sm" onclick="copyImitateResult()">
                  <svg viewBox="0 0 24 24"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg>
                  复制正文
                </button>
                <button class="btn btn-ghost btn-sm" onclick="resetImitate()">
                  <svg viewBox="0 0 24 24"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg>
                  重新仿写
                </button>
              </div>
            </div>
            <div class="panel-body">
              <div class="article-meta-bar">
                <span id="imitate-wordcount"></span>
                <span id="imitate-tags"></span>
                <span id="imitate-profile-used" style="color:#94a3b8;font-size:0.8rem"></span>
              </div>
              <div class="ref-source-bar" id="imitate-ref-source"></div>
              <div class="article-summary-box" id="imitate-summary" style="display:none"></div>
              <div class="article-preview" id="imitate-content"></div>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <script src="app.js?v=20260324i"></script>
</body>
</html>
